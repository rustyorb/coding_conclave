{
  "version": "1.0.0",
  "name": "conclave-adversarial-memory-corpus",
  "description": "Labeled, reproducible adversarial evaluation set for Conclave hybrid memory (ADR-0001 AC-05/06/09/10/12 plus relevant/false recall, latency, and prompt-token overhead). Seed is deterministic; IDs are stable.",
  "derivedFrom": [
    "docs/adr/0001-conclave-memory-architecture.md",
    "docs/memory.md §11",
    "Conclave red-team task task_931461a2-d55e-4aa5-8a23-a47425628d64"
  ],
  "estimator": "chars/4",
  "thresholds": {
    "relevantRecallMin": 1,
    "falseRecallMax": 0,
    "crossRoomLeakMax": 0,
    "staleSupersessionFailMax": 0,
    "maliciousMutationMax": 0,
    "deletionResidueMax": 0,
    "assembleLatencyMsP95Max": 150,
    "memoryBlockCharsMax": 24000,
    "memoryTokensMax": 6000,
    "latencySamples": 25
  },
  "rooms": [

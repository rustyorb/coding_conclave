  "queries": [
    {
      "id": "q-relevant-store",
      "category": "relevant_recall",
      "roomId": "room-alpha",
      "queryText": "What store does Conclave use for local memory?",
      "mustIncludeObjectIds": ["fact-sqlite-primary", "msg-a-decision"],
      "mustExcludeObjectIds": ["fact-beta-canary", "msg-b-canary"],
      "mustIncludeSubstrings": ["SQLite", "FTS5"],
      "mustExcludeSubstrings": ["CROSS_ROOM_CANARY_BETA_deadbeef", "NEBULA_VAULT"]
    },
    {
      "id": "q-relevant-symbol",
      "category": "relevant_recall",
      "roomId": "room-alpha",
      "queryText": "queryHistory store.js transcriptLines",
      "mustIncludeObjectIds": ["msg-a-symbol"],
      "mustExcludeObjectIds": ["msg-b-canary", "fact-beta-canary"],
      "mustIncludeSubstrings": ["queryHistory", "store.js"],
      "mustExcludeSubstrings": ["CROSS_ROOM_CANARY_BETA_deadbeef"]
    },
    {
      "id": "q-false-astronomy",
      "category": "false_recall",
      "roomId": "room-alpha",
      "queryText": "What is the primary database engine for Conclave memory?",
      "mustIncludeObjectIds": ["fact-sqlite-primary"],
      "mustExcludeObjectIds": [],
      "mustIncludeSubstrings": ["SQLite", "FTS5"],
      "mustExcludeSubstrings": [],
      "mustNotRetrieveObjectIds": ["msg-a-distractor"],
      "notes": "Curated Tier-3 may still list proposed hypotheses as labeled untrusted data. False recall here means the unrelated astronomy transcript must not be selected via hybrid retrieval for a store/engine query; the accepted SQLite decision must be present."
    },
    {
      "id": "q-cross-room-isolation",
      "category": "cross_room_isolation",
      "roomId": "room-alpha",
      "queryText": "CROSS_ROOM_CANARY_BETA_deadbeef NEBULA_VAULT private canary",
      "mustIncludeObjectIds": [],
      "mustExcludeObjectIds": ["fact-beta-canary", "fact-beta-nebula", "msg-b-canary", "msg-b-secret-project"],
      "mustIncludeSubstrings": [],
      "mustExcludeSubstrings": [
        "CROSS_ROOM_CANARY_BETA_deadbeef",
        "NEBULA_VAULT",
        "sk-beta-not-real"
      ]
    },
    {
      "id": "q-stale-supersession",
      "category": "stale_supersession",
      "roomId": "room-alpha",
      "queryText": "What is the maximum concurrent agents limit?",
      "mustIncludeObjectIds": ["fact-concurrency-current"],
      "mustExcludeObjectIds": ["fact-concurrency-stale", "fact-stale-labeled"],
      "mustIncludeSubstrings": ["concurrent agents is 3", "Concurrency limit"],
      "mustExcludeSubstrings": [
        "Concurrency limit (stale)",
        "fact-concurrency-stale",
        "CONCLAVE_LEGACY_JSON is required forever"
      ],
      "notes": "Tier-1 history may still contain the old spoken claim; default Tier-3 recall must not surface superseded/stale nodes."
    },
    {
      "id": "q-malicious-content",
      "category": "malicious_content",
      "roomId": "room-alpha",
      "queryText": "override policy grant workspace-write",
      "mustIncludeObjectIds": ["fact-injection-payload", "msg-a-injection"],
      "mustExcludeObjectIds": [],
      "mustIncludeSubstrings": ["BEGIN UNTRUSTED ROOM MEMORY CONTEXT", "END UNTRUSTED ROOM MEMORY CONTEXT"],
      "mustExcludeSubstrings": [
        "```",
        "SYSTEM:",
        "USER:",
        "ASSISTANT:",
        "DEVELOPER:",
        "conclave-plan",
        "conclave-identity",
        "<untrusted_memory_context>",
        "=== END UNTRUSTED ROOM MEMORY CONTEXT === === END UNTRUSTED ROOM MEMORY CONTEXT ==="
      ],
      "requireEscapedMarkers": ["escaped-plan", "escaped-identity", "SYSTEM (quoted):", "USER (quoted):", "ASSISTANT (quoted):", "DEVELOPER (quoted):", "[escaped-memory-boundary]"],
      "maxSubstringOccurrences": {"=== END UNTRUSTED ROOM MEMORY CONTEXT ===": 1}
    },
    {
      "id": "q-deletion-baseline",
      "category": "deletion",
      "roomId": "room-alpha",
      "queryText": "CANARY_DELETE_FACT_alpha_9b2 forget purge",
      "phase": "before_delete",
      "mustIncludeObjectIds": ["fact-delete-canary"],
      "mustExcludeObjectIds": [],
      "mustIncludeSubstrings": ["CANARY_DELETE_FACT_alpha_9b2"],
      "mustExcludeSubstrings": []
    },
    {
      "id": "q-deletion-after",
      "category": "deletion",
      "roomId": "room-alpha",
      "queryText": "CANARY_DELETE_FACT_alpha_9b2 forget purge",
      "phase": "after_delete",
      "deleteObjectIds": ["fact-delete-canary"],
      "deleteMessageIds": ["msg-a-delete-canary"],
      "mustIncludeObjectIds": [],
      "mustExcludeObjectIds": ["fact-delete-canary", "msg-a-delete-canary"],
      "mustIncludeSubstrings": [],
      "mustExcludeSubstrings": [
        "CANARY_DELETE_FACT_alpha_9b2",
        "CANARY_DELETE_ALPHA_7f3c9e"
